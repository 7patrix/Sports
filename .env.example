# Database (Docker maps Postgres to localhost:55432 locally)
DATABASE_URL="postgresql://health:health@localhost:55432/health_funnel?schema=public"

# Queue (Docker maps Redis to localhost:56379 locally)
REDIS_URL="redis://localhost:56379"

# Public app URL
APP_URL="http://localhost:3000"

# AI writer (OpenAI-compatible). Leave MOCK_AI=true to use the deterministic
# fallback writer. To enable the real AI writer, set MOCK_AI=false and provide
# a key. OPENAI_BASE_URL can point at any OpenAI-compatible endpoint (useful if
# api.openai.com is not directly reachable - set it to a reachable gateway).
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
AI_MODEL="gpt-4o-mini"
MOCK_AI="true"

# Optional: route model requests through a proxy when the endpoint is not
# directly reachable (e.g. HTTPS_PROXY="http://127.0.0.1:7890").
# HTTPS_PROXY=""

# Optional: real email delivery via Resend. If unset, the email endpoint still
# captures/stores the address but does not send (graceful degradation).
# RESEND_API_KEY=""
# EMAIL_FROM="Health Twin <noreply@yourdomain.com>"
